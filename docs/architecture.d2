# AI Pipeline System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Entry point on the left - bare card, no zone wrapper.
trigger: Webhook + Cron {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/zap.svg
}

app_zone: "App" {
  api: FastAPI {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

observability_zone: "Observability" {
  sentry: Sentry {
    class: card
    icon: https://cdn.simpleicons.org/sentry
  }
}

data_zone: "Data" {
  grid-columns: 3
  grid-gap: 40

  queue: Redis + DLQ {
    class: card
    icon: https://cdn.simpleicons.org/redis
  }
  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  s3: S3 Artifacts {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

workers_zone: "Workers (19+ isolated)" {
  grid-columns: 3
  grid-gap: 40

  w1: LLM Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  w2: Video Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  more: 17+ more workers {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

integrations_zone: "3rd Party Integrations" {
  grid-columns: 2
  grid-gap: 40

  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  youtube: YouTube API {
    class: card
    icon: https://cdn.simpleicons.org/youtube
  }
}

# L-to-R flow: trigger -> app -> data(queue) -> workers -> integrations
trigger -> app_zone.api: "1. Trigger"
app_zone.api -> data_zone.queue: "2. Enqueue"
data_zone.queue -> workers_zone: "3. Dequeue"
workers_zone -> data_zone: "4. Persist results"
workers_zone -> integrations_zone: "5. External APIs" {
  style.stroke-dash: 3
}
workers_zone -> observability_zone.sentry: "6. Errors + perf" {
  style.stroke-dash: 3
}
