# AI Pipeline System - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: down

triggers: Triggers {
  style.font-size: 18
  style.bold: true

  webhook: Webhook
  cron: Cron
}

api: FastAPI Gateway {
  style.font-size: 18
}

queue: "Redis Queue + DLQ" {
  style.font-size: 18
  style.bold: true
  shape: queue
}

workers: "Worker Pool (19+ tools)" {
  style.font-size: 18
  style.bold: true

  w1: YouTube Worker
  w2: Claude Worker
  w3: Video Worker
  more: "12+ more..."
}

data: "Data Layer" {
  style.font-size: 18
  style.bold: true

  db: Postgres {
    shape: cylinder
  }
  s3: S3 Artifacts {
    shape: cylinder
  }
}

external: "External APIs" {
  style.font-size: 18
  style.bold: true

  claude: Anthropic Claude {
    shape: cloud
  }
  youtube: YouTube Data API {
    shape: cloud
  }
}

triggers.webhook -> api
triggers.cron -> queue
api -> queue: Enqueue
queue -> workers.w1
queue -> workers.w2
queue -> workers.w3
workers.w1 -> external.youtube
workers.w2 -> external.claude
workers.w1 -> data.db
workers.w2 -> data.db
workers.w3 -> data.s3
