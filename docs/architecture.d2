# AI Pipeline System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 60

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Entry point - outside the system
trigger: Webhook + Cron {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/zap.svg
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 30

  api: FastAPI {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
  queue: Redis + DLQ {
    class: card
    icon: https://cdn.simpleicons.org/redis
  }
}

workers_zone: "Workers (19+ isolated)" {
  grid-columns: 3
  grid-gap: 30

  w1: Claude Worker {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  w2: YouTube Worker {
    class: card
    icon: https://cdn.simpleicons.org/youtube
  }
  more: 17+ more workers {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

data_zone: "Data" {
  grid-columns: 2
  grid-gap: 30

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  s3: S3 Artifacts {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

observability_zone: "Observability" {
  sentry: Sentry {
    class: card
    icon: https://cdn.simpleicons.org/sentry
  }
}

trigger -> app_zone.api: "1. Trigger job"
app_zone.api -> app_zone.queue: "2. Enqueue"
app_zone.queue -> workers_zone: "3. Dequeue per tool"
workers_zone -> data_zone: "4. Persist + artifacts"
workers_zone -> observability_zone: "5. Errors + perf" {
  style.stroke-dash: 3
}
