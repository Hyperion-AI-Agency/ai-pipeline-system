# AI Pipeline System - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 240

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
  spacer: {
    shape: rectangle
    width: 160
    height: 160
    style.fill: transparent
    style.stroke: transparent
  }
}

# 3x3 layout:
# Row 0: _       | data | observability
# Row 1: trigger | app  | workers
# Row 2: _       | integrations | _

spacer_tl: "" { class: spacer }

data_zone: "Data" {
  grid-columns: 3
  grid-gap: 80

  queue: Redis Queue {
    class: card
    icon: https://cdn.simpleicons.org/redis
  }
  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  s3: S3 Artifacts {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

observability_zone: "Observability" {
  grid-columns: 1
  grid-gap: 80

  sentry: Sentry {
    class: card
    icon: https://cdn.simpleicons.org/sentry
  }
}

trigger_slot: "" { class: hidden
  grid-columns: 2
  grid-gap: 80

  webhook: Webhook {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/webhook.svg
  }
  cron: Cron {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/clock.svg
  }
}

app_zone: "App" {
  grid-columns: 1
  grid-gap: 80

  api: FastAPI Backend {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

workers_zone: "Workers (19+ isolated)" {
  grid-columns: 1
  grid-gap: 80

  w1: LLM Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  w2: Video Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  more: 17+ more workers {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

spacer_bl: "" { class: spacer }

integrations_zone: "3rd Party Integrations" {
  grid-columns: 2
  grid-gap: 80

  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  youtube: YouTube API {
    class: card
    icon: https://cdn.simpleicons.org/youtube
  }
}

spacer_br: "" { class: spacer }

trigger_slot.webhook -> app_zone.api: "1a. Webhook"
trigger_slot.cron -> app_zone.api: "1b. Cron"
app_zone.api -> data_zone.queue: "2. Enqueue"
data_zone.queue -> workers_zone: "3. Dequeue"
workers_zone -> data_zone.db: "4. Persist"
workers_zone -> data_zone.s3: "5. Artifacts"
workers_zone -> integrations_zone: "6. External APIs"
workers_zone -> observability_zone.sentry: "7. Monitor" {
  style.stroke-dash: 3
}
