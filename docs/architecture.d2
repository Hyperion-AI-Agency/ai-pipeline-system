# AI Pipeline System - Architecture (v5: linear L-to-R flow, stacked core)
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
}

# Layout: [entry] -> [core: Data / App / Integrations stacked] -> [processing] -> [observability]

entry_slot: "" { class: hidden
  grid-columns: 2
  grid-gap: 80

  webhook: Webhook {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/webhook.svg
  }
  cron: Cron {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/clock.svg
  }
}

core: "" { class: hidden
  direction: down

  data_zone: "Data" {
    grid-columns: 3
    grid-gap: 80

    queue: Redis Queue {
      class: card
      icon: https://cdn.simpleicons.org/redis
    }
    db: Postgres {
      class: card
      icon: https://cdn.simpleicons.org/postgresql
    }
    s3: S3 Artifacts {
      class: card
      icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
    }
  }

  app_zone: "App" {
    grid-columns: 1
    grid-gap: 80

    api: FastAPI Backend {
      class: card
      icon: https://cdn.simpleicons.org/fastapi
    }
  }

  integrations_zone: "3rd Party Integrations" {
    grid-columns: 2
    grid-gap: 80

    claude: Claude API {
      class: card
      icon: https://cdn.simpleicons.org/anthropic
    }
    youtube: YouTube API {
      class: card
      icon: https://cdn.simpleicons.org/youtube
    }
  }
}

processing_zone: "Workers (19+ isolated)" {
  grid-columns: 1
  grid-gap: 80

  w1: LLM Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  w2: Video Worker {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/cog.svg
  }
  more: 17+ more workers {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

observability_zone: "Observability" {
  grid-columns: 1
  grid-gap: 80

  sentry: Sentry {
    class: card
    icon: https://cdn.simpleicons.org/sentry
  }
}

# Zone-to-zone arrows only. Max 6. Linear flow.
entry_slot -> core.app_zone: "1. Trigger"
core.app_zone -> core.data_zone: "2. Enqueue"
core.data_zone -> processing_zone: "3. Dequeue"
processing_zone -> core.data_zone: "4. Persist + artifacts"
processing_zone -> core.integrations_zone: "5. External APIs"
processing_zone -> observability_zone: "Monitor" {
  style.stroke-dash: 3
}
