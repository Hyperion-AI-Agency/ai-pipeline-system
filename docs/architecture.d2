# AI Pipeline System - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: down

triggers: Triggers {
  style.bold: true

  webhook: Webhook {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/webhook.svg
  }
  cron: Cron {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/clock.svg
  }
}

api: FastAPI Gateway {
  icon: https://cdn.simpleicons.org/fastapi
}

queue: "Redis Queue + DLQ" {
  icon: https://cdn.simpleicons.org/redis
}

workers: "Worker Pool (19+ tools)" {
  style.bold: true

  w1: YouTube Worker {
    icon: https://cdn.simpleicons.org/youtube
  }
  w2: Claude Worker {
    icon: https://cdn.simpleicons.org/anthropic
  }
  w3: Video Worker {
    icon: https://cdn.simpleicons.org/ffmpeg
  }
  more: "12+ more..." {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

data: "Data Layer" {
  style.bold: true

  db: Postgres {
    icon: https://cdn.simpleicons.org/postgresql
  }
  s3: S3 Artifacts {
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

external: "External APIs" {
  style.bold: true

  claude: Anthropic Claude {
    icon: https://cdn.simpleicons.org/anthropic
  }
  youtube: YouTube Data API {
    icon: https://cdn.simpleicons.org/youtube
  }
}

triggers.webhook -> api
triggers.cron -> queue
api -> queue: Enqueue
queue -> workers.w1
queue -> workers.w2
queue -> workers.w3
workers.w1 -> external.youtube
workers.w2 -> external.claude
workers.w1 -> data.db
workers.w2 -> data.db
workers.w3 -> data.s3
