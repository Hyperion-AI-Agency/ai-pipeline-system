# AI Pipeline System - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: right
grid-columns: 2
grid-gap: 80

classes: {
  card: {
    width: 160
    height: 160
  }
}

trigger: Webhook + Cron {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/zap.svg
}

api: FastAPI Gateway {
  class: card
  icon: https://cdn.simpleicons.org/fastapi
}

queue: "Redis Queue + DLQ" {
  class: card
  icon: https://cdn.simpleicons.org/redis
}

workers: "Worker Pool (19+ tools)" {
  style.bold: true

  w1: Claude Worker {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  w2: YouTube Worker {
    class: card
    icon: https://cdn.simpleicons.org/youtube
  }
  more: "17+ more workers" {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/layers.svg
  }
}

data: "Data Layer" {
  style.bold: true

  db: Postgres {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
  s3: S3 Artifacts {
    class: card
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

sentry: Sentry {
  class: card
  icon: https://cdn.simpleicons.org/sentry
}

trigger -> api: "1. Trigger job"
api -> queue: "2. Enqueue"
queue -> workers.w1: "3a. Dequeue"
queue -> workers.w2: "3b. Dequeue"
queue -> workers.more: "3c. Dequeue"
workers.w1 -> data.db: "4a. Persist result"
workers.w2 -> data.db: "4b. Persist result"
workers.more -> data.s3: "4c. Store artifact"
workers -> sentry: "5. Errors + perf" {
  style.stroke-dash: 3
}
