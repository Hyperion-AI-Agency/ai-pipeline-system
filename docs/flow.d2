# AI Pipeline System - Job Lifecycle
# Render: d2 --theme 0 --pad 120 --scale 1.5 --layout dagre docs/flow.d2 docs/flow.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

shape: sequence_diagram

trigger: Trigger {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/zap.svg
}
api: FastAPI {
  icon: https://cdn.simpleicons.org/fastapi
}
queue: Redis Queue {
  icon: https://cdn.simpleicons.org/redis
}
worker: Worker {
  icon: https://cdn.simpleicons.org/anthropic
}
db: Postgres {
  icon: https://cdn.simpleicons.org/postgresql
}

trigger -> api: "1. POST /jobs"
api -> db: "2. Persist (queued)"
api -> queue: "3. Enqueue"
api -> trigger: "4. 202 + job_id" {
  style.stroke: "#059669"
}
queue -> worker: "5. Dequeue"
worker -> worker: "6. Run task"
worker -> db: "7. Update (done)" {
  style.stroke: "#059669"
  style.bold: true
}
worker -> trigger: "8. Webhook: done"
